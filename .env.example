# Supabase — variáveis de ambiente (Craft Oficina)
# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase.

# URL do projeto (Settings → API → Project URL)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon/public (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Persistência: local = localStorage (padrão atual) | supabase = banco remoto (futuro)
# Mantenha "local" até login e migração estarem concluídos.
VITE_CRAFT_PERSISTENCE=local
