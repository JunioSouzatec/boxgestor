# BoxGestor — variáveis de ambiente
# Copie para .env.local (desenvolvimento) ou configure na Vercel/Netlify (produção).

# --- Supabase (obrigatório em produção) ---
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# --- App ---
VITE_APP_NAME=BoxGestor
# URL pública do deploy (sem barra no final). Ex.: https://boxgestor.vercel.app
# Usada em links de convite, cadastro e recuperação de senha quando necessário.
VITE_APP_URL=

# --- Modo produção online (recomendado) ---
# Em build PROD com Supabase configurado, o padrão já é supabase se não for "local".
VITE_CRAFT_PERSISTENCE=supabase
VITE_CRAFT_AUTH=supabase

# --- Administrador do Sistema (Admin BoxGestor) ---
# Separe vários e-mails por vírgula. Também cadastre em system_admin_emails no Supabase
# (docs/supabase-admin-system.sql).
VITE_SYSTEM_ADMIN_EMAILS=seu@email.com

# --- Desenvolvimento local (opcional) ---
# VITE_CRAFT_PERSISTENCE=local
# VITE_CRAFT_AUTH=local
