# BoxGestor — variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase.

# URL do projeto (Settings → API → Project URL)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon/public (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Persistência:
#   local    = localStorage (padrão, recomendado para uso diário)
#   supabase = modo experimental — oficina, clientes, motos e OS no Supabase (fase 1)
VITE_CRAFT_PERSISTENCE=local

# Autenticação:
#   local    = login demo (craft_auth_v1 no localStorage) — padrão
#   supabase = Supabase Auth real (e-mail/senha). Requer docs/supabase-auth-rls.sql
VITE_CRAFT_AUTH=local

# Administrador do Sistema (suporte BoxGestor) — NÃO mostrar à oficina cliente.
# Separe vários e-mails por vírgula. Reinicie o dev server após alterar.
# VITE_SYSTEM_ADMIN_EMAILS=seu@email.com
